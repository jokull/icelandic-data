# Data (large files, regenerable)
data/raw/
data/processed/
data/geodata/

# DuckDB
*.duckdb
*.duckdb.wal

# Python
__pycache__/
*.py[cod]
.venv/
.uv/

# Playwright browsers
.playwright/

# HTML reports (self-contained, local only)
reports/*.html
# Rendered report images (regenerable via scripts)
reports/*.png

# Claude plans
.claude/plans/

# Local Claude settings (machine-specific permission grants)
.claude/settings.local.json

# R
.Rhistory
.Rdata
.Rproj.user/

# Raw data downloads under non-standard paths
data/logbyli/

# Scratch metadata files written by scripts at runtime
metadata/maelabord-ctx*.txt

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
