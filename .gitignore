# Data (large files, regenerable)
data/raw/
data/processed/
data/geodata/

# DuckDB
*.duckdb
*.duckdb.wal

# Python
__pycache__/
*.py[cod]
.venv/
.python-version
.uv/

# Playwright browsers
.playwright/

# Reports (self-contained HTML + one-off report scripts, local only)
reports/*
!reports/.gitkeep

# Claude plans
.claude/plans/

# Local Claude settings (machine-specific permission grants)
.claude/settings.local.json

# R
.Rhistory
.Rdata
.Rproj.user/

# Raw data downloads under non-standard paths
data/logbyli/

# Scratch metadata files written by scripts at runtime
metadata/maelabord-ctx*.txt

# Tesseract language data (downloaded on demand)
*.traineddata

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
